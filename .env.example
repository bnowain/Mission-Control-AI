# Mission Control — Environment Variables
# Copy to .env and fill in your keys. Never commit .env to git.

# ─── Cloud Provider API Keys ──────────────────────────────────────────────────
# Leave blank to disable that provider. LiteLLM skips deployments with null keys.

# Anthropic — required for planner_model (claude-opus-4-6) and fast fallback (haiku)
ANTHROPIC_API_KEY=

# DeepSeek — optional cloud reasoning/planner fallback (deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=

# OpenAI — optional cloud fallback across all tiers (gpt-4.1, gpt-4.1-mini, gpt-4.1-nano)
OPENAI_API_KEY=

# ─── Local Model Server ───────────────────────────────────────────────────────
# Ollama runs on this by default. Override if you run on a different host/port.
OLLAMA_API_BASE=http://localhost:11434

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave unset to use the default: database/mission_control.db
# MC_DB_PATH=database/mission_control.db

# ─── Application ──────────────────────────────────────────────────────────────
MC_PORT=8860
MC_LOG_LEVEL=INFO
